{
  "version": 2,
  "buildCommand": "npm run build && mkdir -p api && cp -r dist/public api/public",
  "builds": [
    {
      "src": "server/vercel-entry.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "api/public/**",
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server/vercel-entry.ts" }
  ],
  "crons": [
    {
      "path": "/api/trigger-fetch",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/trigger-fetch",
      "schedule": "0 14 * * *"
    }
  ]
}
